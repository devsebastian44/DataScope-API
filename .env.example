# API Configuration
API_V1_PREFIX=/api/v1
PROJECT_NAME=EDA API - Exploratory Data Analysis
VERSION=1.0.0

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# Data Processing
MAX_ROWS_PREVIEW=100
DEFAULT_CHUNK_SIZE=10000

# Visualization
PLOT_DPI=100